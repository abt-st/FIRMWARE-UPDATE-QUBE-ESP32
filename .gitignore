# ──────────────────────────────────────────────────────────────────────────────
#  .gitignore — QUBE ESP32 Project
# ──────────────────────────────────────────────────────────────────────────────

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── Entorno virtual ─────────────────────────────────────────────────────────
.venv/
venv/
ENV/

# ── Herramientas de calidad ─────────────────────────────────────────────────
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/

# ── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Datos experimentales (archivos pesados) ─────────────────────────────────
data/*.csv
data/*.dat
!data/README.md

# ── PlatformIO ──────────────────────────────────────────────────────────────
.pio/
.pioenvs/
.piolibdeps/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# ── Firmware builds ─────────────────────────────────────────────────────────
*.bin
*.hex
*.elf
*.map

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Archivos temporales ─────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
# ── Credenciales WiFi (nunca commitear) ─────────────────────────────────────
credentials.h
